rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Allow authenticated users to read and write their own profile
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Allow authenticated users to read and write sows
    match /sows/{sowId} {
      allow read, write: if isAuthenticated();
      
      // Allow authenticated users to read and write activities for a sow
      match /activities/{activityId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    // Allow collection group queries for activities
    match /{path=**}/activities/{activityId} {
      allow read: if isAuthenticated();
    }

    // Allow authenticated users to read and write sales
    match /sales/{saleId} {
      allow read, write: if isAuthenticated();
    }

    // Allow authenticated users to read and write expenses
    match /expenses/{expenseId} {
      allow read, write: if isAuthenticated();
    }
  }
}
