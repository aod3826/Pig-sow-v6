{
  "entities": {
    "Sow": {
      "title": "Sow",
      "description": "A sow in the farm",
      "type": "object",
      "properties": {
        "breed": { "type": "string" },
        "birthDate": { "type": "string", "format": "date-time" },
        "entryDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["IDLE", "BRED", "PREGNANT", "PREPARING", "NURSING", "CULL_SUGGESTED", "CULLED"] },
        "parity": { "type": "number" },
        "currentCycleStartDate": { "type": "string", "format": "date-time" },
        "farrowDate": { "type": "string", "format": "date-time" },
        "weanDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["status", "parity", "entryDate"]
    },
    "Activity": {
      "title": "Activity",
      "description": "An event in the sow's lifecycle",
      "type": "object",
      "properties": {
        "sowId": { "type": "string" },
        "type": { "type": "string", "enum": ["ENTRY", "BREED", "CHECK_ESTRUS", "ULTRASOUND", "FEED_BOOST", "MOVE_TO_PEN", "FARROW", "WEAN", "RETURN_ESTRUS", "CULL", "HEALTH_NOTE"] },
        "date": { "type": "string", "format": "date-time" },
        "parity": { "type": "number" },
        "notes": { "type": "string" },
        "noteCategory": { "type": "string", "enum": ["SICK", "VACCINE", "GENERAL"] },
        "breedingMethod": { "type": "string", "enum": ["NATURAL", "ARTIFICIAL"] },
        "boarId": { "type": "string" },
        "semenId": { "type": "string" },
        "semenSource": { "type": "string" },
        "inseminator": { "type": "string" },
        "pregResult": { "type": "string", "enum": ["POSITIVE", "NEGATIVE", "ABORTION"] },
        "pigletCount": { "type": "number" },
        "liveBorn": { "type": "number" },
        "stillborn": { "type": "number" },
        "mummified": { "type": "number" },
        "avgBirthWeight": { "type": "number" },
        "weanedCount": { "type": "number" },
        "totalWeanWeight": { "type": "number" },
        "cullReason": { "type": "string" },
        "cullPrice": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sowId", "type", "date", "parity"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A record of fattening pigs sale",
      "type": "object",
      "properties": {
        "buyerName": { "type": "string" },
        "buyerEmail": { "type": "string" },
        "vehicleReg": { "type": "string" },
        "date": { "type": "string" },
        "weighings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "pigCount": { "type": "number" },
              "grossWeight": { "type": "number" },
              "tareWeight": { "type": "number" },
              "netWeight": { "type": "number" }
            }
          }
        },
        "totalPigs": { "type": "number" },
        "totalNetWeight": { "type": "number" },
        "avgWeight": { "type": "number" },
        "pricePerKg": { "type": "number" },
        "grossTotal": { "type": "number" },
        "deductions": { "type": "number" },
        "netTotal": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["PAID", "UNPAID"] },
        "signature": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerName", "date", "totalPigs", "totalNetWeight", "paymentStatus"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A record of farm expenses",
      "type": "object",
      "properties": {
        "category": { "type": "string", "enum": ["FEED", "MEDICINE", "EQUIPMENT", "MAINTENANCE", "UTILITIES", "SALARY", "OTHER"] },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "amount", "date"]
    }
  },
  "firestore": {
    "/sows/{sowId}": {
      "schema": { "$ref": "#/entities/Sow" },
      "description": "Stores all sows"
    },
    "/sows/{sowId}/activities/{activityId}": {
      "schema": { "$ref": "#/entities/Activity" },
      "description": "Stores activities for a specific sow"
    },
    "/sales/{saleId}": {
      "schema": { "$ref": "#/entities/Sale" },
      "description": "Stores all sales records"
    },
    "/expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "Stores all farm expenses"
    }
  }
}
